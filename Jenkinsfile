pipeline {
    agent any

    stages {

        stage('Checkout') {
            steps {
                echo 'Downloading Source Code'
            }
        }

        stage('Build') {
            steps {
                echo 'Building Web Application'
            }
        }

        stage('Test') {
            steps {
                echo 'Testing Application'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deploying Application'
            }
        }
    }
}
